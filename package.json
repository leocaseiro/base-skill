{
  "name": "base-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "start": "yarn dev",
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:vr": "node scripts/vr-docker.mjs test",
    "test:vr:update": "node scripts/vr-docker.mjs update",
    "test:vr:report": "playwright show-report",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build",
    "test:storybook": "test-storybook",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 && knip --no-config-hints",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#.specstory' '#.cursor' '#dist' '#worktrees'",
    "format": "prettier --check .",
    "fix": "prettier --write . && eslint --fix .",
    "fix:css": "stylelint --fix 'src/**/*.css' && prettier --write 'src/**/*.css'",
    "fix:md": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#.specstory' '#.cursor' '#dist' '#worktrees' && prettier --write '**/*.md'",
    "preinstall": "node scripts/check-node-version.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "i18next": "^26.0.3",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "rxdb": "^17.0.0",
    "rxjs": "^7.8.2",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@mdx-js/react": "^3.0.0",
    "@playwright/test": "1.59.1",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-themes": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@storybook/test-runner": "0.24.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "^0.3.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.1.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "rehype-format": "^5.0.1",
    "rehype-raw": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "storybook": "10.3.3",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wait-on": "^8.0.0",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  }
}
